# ─── Apify ───────────────────────────────────────────────────────────────────
# Used to scrape X (Twitter) posts via the apidojo/tweet-scraper actor.
# Requires a paid Apify plan (Free plan blocks API access).
#
# How to get:
#   1. Sign up at https://apify.com
#   2. Upgrade to a paid plan at https://apify.com/pricing
#   3. Go to Settings → Integrations → API tokens → Create new token
APIFY_TOKEN=apify_api_...

# ─── Anthropic ───────────────────────────────────────────────────────────────
# Used to generate news articles from scraped posts via Claude.
#
# How to get:
#   1. Sign up at https://console.anthropic.com
#   2. Go to Settings → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-...
